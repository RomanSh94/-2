# Скопируй этот файл в .env.test и впиши ТЕСТОВЫЙ токен (НЕ боевой!).
# .env.test в .gitignore — в репозиторий не попадёт.

# Обязательно: токен ОТДЕЛЬНОГО тест-бота от @BotFather (не прод-токен!).
BOT_TOKEN=

# Необязательно для кризис-теста (кризисный путь LLM не зовёт). Можно вписать
# свой ключ, чтобы проверить «возврат в обычный чат», или оставить пустым —
# тогда после кризиса бот ответит «временно недоступен», что тоже доказывает
# выход из кризис-режима.
OPENAI_API_KEY=

# Пароль для тест-дашборда (любой).
ADMIN_PASSWORD=test

# Необязательно: твой числовой Telegram user_id, чтобы получать админ-алерты
# (стадия 1/3). Узнать id можно у @userinfobot. Несколько — через запятую.
ADMIN_USER_IDS=

# PR C3a — questionnaire interpretation kill switch. Default false everywhere,
# including here. Set to true ONLY in your own local, untracked .env.test to
# run the controlled smoke checklist in docs/runbooks/questionnaire_c3a_smoke.md
# -- never in .env / production. See CLINICAL_BOUNDARY.md §0.5 point 5: this
# does not authorize production enable on its own.
QUESTIONNAIRE_INTERPRETATION_ENABLED=false

# Temporary test invite access. Test instance only (X20_TEST_INSTANCE=1 AND
# database.DB=="x20_test.db" both required, see access_control.py). Lets any
# Telegram account holding the invite code self-grant temporary test access
# for up to 72 hours. Must remain false/unset by default; never set in .env
# (production) — only in your own local, untracked .env.test.
TEMP_TEST_INVITE_ENABLED=false
TEMP_TEST_INVITE_CODE=
TEMP_TEST_INVITE_START_UTC=
TEMP_TEST_INVITE_END_UTC=
