BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Admin dashboard
ADMIN_PASSWORD=change_me_please
ADMIN_PORT=8080
ADMIN_USER_IDS=123456789

# Email alerts (leave blank to disable)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_TO=admin@yourdomain.com

# Webhook alerts (Slack/Discord/custom, leave blank to disable)
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# A/B testing variants (comma-separated)
AB_VARIANTS=control,variant_a

# Private invite-based access for ordinary product users (PR A). Lets you
# send a Telegram deep link (https://t.me/<bot>?start=<code>) so a real user
# can self-register as an ordinary user, WITHOUT pre-adding their Telegram id
# anywhere. Does NOT grant OWNER/CLINICIAN access. Default off. If enabled,
# USER_INVITE_CODE must be a real random secret of at least 24 characters
# (e.g. `python -c "import secrets;print(secrets.token_urlsafe(32))"`) --
# never commit the real value.
USER_INVITE_ENABLED=false
USER_INVITE_CODE=

# PR #55 — owner-only Russian DASS-21 (disabled by default; see docs/dass21_owner_integration.md)
DASS21_ENABLED=false
DASS21_OWNER_ONLY=true
DASS21_DEFINITION_PATH=private_questionnaires/dass21_ru_fattakhov_2024.json
DASS21_DEFINITION_SHA256=
# Two-flag model (operationally non-obvious -- read carefully):
#   DASS21_OWNER_ONLY=true   is a CONFIG-SANITY guard: setting it false fails
#                            closed for EVERYONE (owner included). It is NOT
#                            the way to open access and must stay true.
#   DASS21_INVITED_USERS_ENABLED  is the ONLY switch that admits non-owners:
#                            when true, users with an ACTIVE user_access row
#                            get DASS (owner keeps access regardless).
# Invited beta therefore runs with OWNER_ONLY=true + INVITED_USERS_ENABLED=true.
DASS21_INVITED_USERS_ENABLED=false
# DASS-21 "discuss result" via the existing q:m:<session_id> namespace
# (Workstream B). Default off.
DASS21_DISCUSSION_ENABLED=false

# First-user illustrated onboarding (5 screens shown to genuinely NEW authorized
# users before the existing mood entry). Default OFF -> /start behaves exactly as
# before. When ON it affects ONLY brand-new eligible users; returning and legacy
# users are untouched. Rollback: set this back to false (onboarding metadata and
# questionnaires are unaffected). See docs/first_user_onboarding.md.
FIRST_USER_ONBOARDING_ENABLED=false
# Optional. If you have a real, published Privacy Policy URL, put it here and the
# onboarding privacy screen shows it as a link button. Leave BLANK (default) to
# fall back to a deterministic in-bot privacy summary + /privacy_export_all /
# /privacy_delete_all. Never invent a URL that does not resolve.
PRIVACY_POLICY_URL=

# Voice and Adaptive Response UX — both default OFF. VOICE_REPLIES_ENABLED
# gates /format, the listen button, format meta-commands, and preference-
# driven delivery; flag false = plain text replies exactly as before.
# EMOTIONAL_REACTIONS_ENABLED gates only the best-effort Telegram message
# reaction and is independent of the flag above.
VOICE_REPLIES_ENABLED=false
EMOTIONAL_REACTIONS_ENABLED=false
# TTS configuration -- inert while VOICE_REPLIES_ENABLED is false.
TTS_MODEL=tts-1
TTS_VOICE_RU=alloy
TTS_VOICE_EN=alloy
TTS_RESPONSE_FORMAT=opus
TTS_TIMEOUT_SECONDS=20
TTS_MAX_INPUT_CHARS=600
TTS_MAX_AUDIO_SECONDS=90
# Reaction configuration -- inert while EMOTIONAL_REACTIONS_ENABLED is false.
EMOTIONAL_REACTION_COOLDOWN_SECONDS=120
EMOTIONAL_REACTION_MIN_CONFIDENCE=0.6
# Bounded TTLs (configuration values, not rollout flags) for the ephemeral
# FSM-scoped one-shot voice override and last-delivered-response replay.
VOICE_ONE_SHOT_OVERRIDE_TTL_SECONDS=300
VOICE_LAST_RESPONSE_TTL_SECONDS=21600
